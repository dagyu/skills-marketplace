#!/usr/bin/env bash
# SessionStart hook for the workflow plugin.
# Injects the workflow-overview skill as session context so the agent knows the
# brainstorm → plan → implement phases and the workflow CLI from the first turn.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

overview_content=$(cat "${PLUGIN_ROOT}/skills/workflow-overview/SKILL.md" 2>&1 || echo "Error reading workflow-overview skill")

# Escape a string for embedding inside a JSON string literal.
escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

overview_escaped=$(escape_for_json "$overview_content")
session_context="<EXTREMELY_IMPORTANT>\nThis project uses the workflow plugin (brainstorm → plan → implement).\n\n**Below is the full content of the 'workflow-overview' skill. For the brainstorming, planning, and implementation skills, use the 'Skill' tool when the phase calls for them.**\n\n${overview_escaped}\n</EXTREMELY_IMPORTANT>"

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"

exit 0
